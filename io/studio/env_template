# sample .env file for I/O runtime actions

AIO_runtime_auth=xxxxx
AIO_runtime_namespace=14257-masstudio-xxxx
AIO_runtime_apihost=https://adobeioruntime.net

# project specific variables

 # odin author
ODIN_ENDPOINT=https://author-p22655-xxxx.adobeaemcloud.com

# ost-products-write action
AOS_URL=
AOS_API_KEY=
OST_WRITE_API_KEY=

# batch size of concurrent requests to send to odin loc v2 API ODIN_ENDPOINT (default: 2, QA-safe)
BATCH_SIZE=2

# max sustained requests per second sent to odin (default: 2, QA-safe)
# NOTE: batch_size must not exceed rps_limit — each batch fires all requests simultaneously,
# so a batch larger than the RPS limit would burst past the limit before throttling applies.
# Cluster HTTP RPS ≈ WORKER_CONCURRENCY × RPS_LIMIT × 2 (≈ 8 RPS under these QA-safe defaults).
RPS_LIMIT=2

# Maximum number of translation workers running in parallel against Odin authoring (default: 2).
# Stage/prod values are set via the io-studio-merge.yaml workflow, not this file.
WORKER_CONCURRENCY=2

# translation state TTLs (package-level inputs)
TRANSLATION_JOB_PAYLOAD_TTL=
TRANSLATION_PROJECT_SUMMARY_TTL=
