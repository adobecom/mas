{
  "name": "MerchAtScaleStudio",
  "version": "0.0.1",
  "private": true,
  "dependencies": {
    "@adobe/aio-lib-files": "^4",
    "@adobe/aio-lib-ims": "^7.0.2",
    "@adobe/aio-lib-state": "^5.1.0",
    "@adobe/aio-sdk": "^6",
    "@adobe/exc-app": "^1.3.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1018.0",
    "cloudevents": "^4.0.2",
    "node-fetch": "^2.6.0",
    "regenerator-runtime": "^0.13.5",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@adobe/aio-cli": "^11.0.1",
    "@esm-bundle/chai": "4.3.4-fix.0",
    "c8": "^10.1.3",
    "chai": "^4.3.6",
    "eslint": "^8",
    "esm": "^3.2.25",
    "mocha": "^10.2.0",
    "nock": "^13.0.0",
    "proxyquire": "^2.1.3",
    "sinon": "^15.0.0",
    "sinon-chai": "^3.7.0"
  },
  "scripts": {
    "eval": "node test/ai-chat-eval.mjs",
    "test": "c8 mocha --recursive --ignore 'test/ai-chat-eval.mjs' ./test",
    "test:ci": "c8 mocha --recursive --ignore 'test/ai-chat-eval.mjs' ./test",
    "test:watch": "mocha --watch --recursive --ignore 'test/ai-chat-eval.mjs' ./test",
    "test:file": "mocha --watch --recursive --ignore 'test/ai-chat-eval.mjs' --grep",
    "test:coverage": "c8 mocha --recursive --ignore 'test/ai-chat-eval.mjs' ./test",
    "test:coverage:file": "c8 mocha",
    "test:coverage:html": "c8 --reporter=html --reporter=text mocha --recursive ./test",
    "lint": "eslint --ignore-pattern web-src --no-error-on-unmatched-pattern test src actions",
    "lint:fix": "npm run lint -- --fix",
    "build:knowledge": "node scripts/build-knowledge-corpus.mjs"
  },
  "engines": {
    "node": ">=22"
  }
}
